{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*"
    ],
    "headers": [
      {
        "source": "**/*.@(html|json)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/home",
        "destination": "/Home_n4x8k2.html"
      },
      {
        "source": "/dashboard",
        "destination": "/Dash_9f3k2.html"
      },
      {
        "source": "/products",
        "destination": "/Produ_p82mx.html"
      },
      {
        "source": "/support",
        "destination": "/Suppo_q5w91.html"
      }
    ]
  }
}
